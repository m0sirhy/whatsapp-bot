<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
</head>
<body class="p-4">
    <div class="container">
        <h3><%= title %></h3>
        <%- body %>
    </div>

    <audio id="notifySound" src="/sounds/notify.mp3" preload="auto"></audio>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
    function initDataTable(tableId, ajaxUrl, actionButtons=[]){
        const table = $(tableId).DataTable({
            "ajax": ajaxUrl,
            "columns": [
                { "data":"name" },
                { "data":"amount" },
                { "data":"sender" },
                { "data":"senderNumber" },
                { "data":"senderName" },
                { "data":"datePayment" },
                { "data":"dateRecorded" },
                { 
                    "data":"receipt",
                    "render": function(data){
                        if(data && data!=="لا يوجد"){
                            const fileName = data.split(/[/\\]/).pop();
                            return `<a href="/receipts/${fileName}" target="_blank" class="btn btn-sm btn-primary mb-1">فتح</a><br>
                                    <img src="/receipts/${fileName}" class="img-thumbnail">`;
                        } else return '<span class="text-muted">لا يوجد</span>';
                    }
                },
                {
                    "data":"id",
                    "render": function(id){
                        return actionButtons.map(btn=>{
                            return `<button class="btn btn-sm ${btn.class}" data-id="${id}">${btn.text}</button>`;
                        }).join(' ');
                    }
                }
            ],
            "language": { "url":"https://cdn.datatables.net/plug-ins/1.13.6/i18n/ar.json" },
            "pageLength":10
        });

        // ربط أزرار الإجراءات
        actionButtons.forEach(btn=>{
            $(tableId).on('click', `.${btn.class}`, function(){
                const id = $(this).data('id');
                if(btn.confirm && !confirm(btn.confirm)) return;
                $.post(btn.url.replace(':id', id), ()=>table.ajax.reload(null,false));
            });
        });

        // تحديث تلقائي مع صوت
        let lastCount = 0;
        setInterval(()=>{
            table.ajax.reload(null,false).done(()=>{
                const currentCount = table.data().count();
                if(currentCount > lastCount) document.getElementById('notifySound').play();
                lastCount = currentCount;
            });
        }, 2000);
    }
    </script>
</body>
</html>