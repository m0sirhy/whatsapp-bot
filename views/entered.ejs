<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>الدفعات المدخلة للنظام</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        img { max-width: 100px; height: auto; }
        table.dataTable tbody tr:nth-child(even) { background-color: #f9f9f9; }
        table.dataTable tbody tr:hover { background-color: #d1ecf1 !important; }
        th { text-align: right; }
        td { vertical-align: middle; }
    </style>
</head>
<body>
<div class="container">
        <%- include('partials/navbar') %>

    <h1 class="mb-4 text-center">الدفعات المدخلة للنظام</h1>

    <table id="enteredTable" class="table table-striped table-bordered" style="width:100%">
        <thead class="table-dark">
        <tr>
            <th>اسم المشترك</th>
            <th>قيمة الدفعة</th>
            <th>صاحب الحساب المرسل</th>
            <th>رقم المرسل</th>
            <th>اسم المرسل</th>
            <th>تاريخ الدفعة</th>
            <th>تاريخ التسجيل</th>
            <th>الإشعار</th>
        </tr>
        </thead>
    </table>
</div>

<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- DataTables JS -->
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

<script>
$(document).ready(function() {
    const table = $('#enteredTable').DataTable({
        ajax: {
                    url: "/api/payments/entered",
                    dataSrc: ""
                },

        columns: [
            { data: "name" },
            { data: "amount" },
            { data: "sender" },
            { data: "senderNumber" },
            { data: "senderName" },
            { data: "datePayment" },
            { data: "dateRecorded" },
            {
                data: "receipt",
                render: function(data) {
                    if(data && data !== "لا يوجد") {
                        const fileName = data.split(/[/\\]/).pop();
                        return `<a href="/receipts/${fileName}" target="_blank" class="btn btn-sm btn-primary mb-1">فتح</a><br>
                                <img src="/receipts/${fileName}" class="img-thumbnail">`;
                    } else {
                        return '<span class="text-muted">لا يوجد</span>';
                    }
                }
            }
        ],
        language: { url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/ar.json" },
        pageLength: 10
    });

    // تحديث تلقائي كل 2 ثانية
    setInterval(() => table.ajax.reload(null, false), 2000);
});
</script>
</body>
</html>