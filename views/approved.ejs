<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <title>الدفعات المقبولة</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
</head>

<body class="p-4">
    <div class="container">
        <%- include('partials/navbar') %>

            <h1 class="mb-4 text-center">الدفعات المقبولة</h1>
            <table id="approvedTable" class="table table-striped table-bordered" style="width:100%">
                <thead class="table-dark">
                    <tr>
                        <th>اسم المشترك</th>
                        <th>قيمة الدفعة</th>
                        <th>صاحب الحساب المرسل</th>
                        <th>رقم المرسل</th>
                        <th>اسم المرسل</th>
                        <th>تاريخ الدفعة</th>
                        <th>تاريخ تسجيل الدفعة</th>
                        <th>الإشعار</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
            </table>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            const table = $('#approvedTable').DataTable({

                ajax: {
                    url: "/api/payments/approved",
                    dataSrc: ""
                },

                columns: [
                    { data: "name" },
                    { data: "amount" },
                    { data: "sender" },
                    { data: "senderNumber" },
                    { data: "senderName" },
                    { data: "datePayment" },
                    { data: "dateRecorded" },
                    {
                        data: "receipt",
                        render: function (data) {
                            if (data && data !== "لا يوجد") {
                                const fileName = data.split(/[/\\]/).pop();
                                return `<a href="/receipts/${fileName}" target="_blank" class="btn btn-sm btn-primary mb-1">فتح</a><br>
                                <img src="/receipts/${fileName}" class="img-thumbnail" style="max-width:120px">`;
                            } else return '<span class="text-muted">لا يوجد</span>';
                        }
                    },
                    {
                        data: "id",
                        render: function (id, type, row) {
                            return `<button class="btn btn-success btn-sm mark-entered-btn" 
                                data-id="${id}" 
                                data-number="${row.senderNumber}" 
                                data-name="${row.senderName}">
                                تم الإدخال
                            </button>`;
                        }
                    }
                ],
                language: { url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/ar.json" },
                pageLength: 10
            });

            $('#approvedTable').on('click', '.mark-entered-btn', function () {
                const id = $(this).data('id');
                const number = $(this).data('number');
                const name = $(this).data('name');

                if (confirm(`هل تريد التأكيد على أن الدفعة تم إدخالها للنظام؟`)) {
                    // تحديث الحالة في السيرفر
                    $.post(`/api/payments/mark-entered/${id}`, function (resp) {
                        if (resp.success) {
                            alert("تم تحديث الحالة ✅");

                            // تأكد من تنسيق الرقم بشكل صحيح للبوت
                            const formattedNumber = number.includes('@') ? number : `${number}@c.us`;

                            // إرسال رسالة واتساب للمستخدم عبر البوت
                            $.post(`/api/send-whatsapp-message`, {
                                number: formattedNumber,
                                message: `مرحباً ${name}، تم ادخال الدفعة على حسابك في النظام بنجاح ✅`
                            })
                                .done(() => {
                                    console.log("تم إرسال الرسالة بنجاح");
                                })
                                .fail(err => {
                                    console.error("خطأ في إرسال الرسالة:", err);
                                    alert("حدث خطأ أثناء إرسال رسالة WhatsApp ❌");
                                });

                            // إعادة تحميل الجدول
                            table.ajax.reload(null, false);
                        }
                    });
                }
            });
        });
    </script>
</body>

</html>